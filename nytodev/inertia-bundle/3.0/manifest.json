{
    "bundles": {
        "Nytodev\\InertiaBundle\\InertiaBundle": ["all"]
    },
    "copy-from-recipe": {
        "config/": "%CONFIG_DIR%/"
    },
    "add-lines": [
        {
            "file": "templates/base.html.twig",
            "content": "        {{ inertiaHead(page) }}",
            "position": "after_target",
            "target": "{% block javascripts %}",
            "warn_if_missing": true
        },
        {
            "file": "templates/base.html.twig",
            "content": "        {{ inertia(page) }}",
            "position": "after_target",
            "target": "{% block body %}",
            "warn_if_missing": true
        }
    ]
}
